<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/card_bg">

    <!-- Role badge -->
    <TextView
        android:id="@+id/tv_profile_role_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/badge_bg"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Entrant"
        android:textColor="@color/badge_green_text"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- User name -->
    <TextView
        android:id="@+id/tv_profile_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/dark_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btn_profile_remove"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_profile_role_badge"
        tools:text="Jane Doe" />

    <!-- Email row -->
    <ImageView
        android:id="@+id/iv_profile_email_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="6dp"
        android:src="@android:drawable/ic_dialog_email"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_profile_name"
        app:tint="@color/gray_text" />

    <TextView
        android:id="@+id/tv_profile_email"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textColor="@color/gray_text"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_profile_email_icon"
        app:layout_constraintEnd_toStartOf="@id/btn_profile_remove"
        app:layout_constraintStart_toEndOf="@id/iv_profile_email_icon"
        app:layout_constraintTop_toTopOf="@id/iv_profile_email_icon"
        tools:text="jane.doe@example.com" />

    <!-- ID row -->
    <ImageView
        android:id="@+id/iv_profile_id_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="4dp"
        android:src="@android:drawable/ic_menu_info_details"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_profile_email_icon"
        app:tint="@color/gray_text" />

    <TextView
        android:id="@+id/tv_profile_id"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textColor="@color/gray_text"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/iv_profile_id_icon"
        app:layout_constraintEnd_toStartOf="@id/btn_profile_remove"
        app:layout_constraintStart_toEndOf="@id/iv_profile_id_icon"
        app:layout_constraintTop_toTopOf="@id/iv_profile_id_icon"
        tools:text="ID: #a3f2" />

    <!-- Remove button -->
    <Button
        android:id="@+id/btn_profile_remove"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:backgroundTint="#F04438"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:text="Remove"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/iv_profile_id_icon" />

</androidx.constraintlayout.widget.ConstraintLayout>
