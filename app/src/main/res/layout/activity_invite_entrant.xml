<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_invite_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_blue"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/btn_invite_back"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tv_invite_event_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Mode toggle -->
    <LinearLayout
        android:id="@+id/ll_invite_mode_toggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/ll_invite_header">

        <Button
            android:id="@+id/btn_mode_search"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/primary_blue"
            android:text="Search Users"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/btn_mode_invited"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Invited (0)"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Search bar (hidden in Invited mode) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_invite_search"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/ll_invite_mode_toggle">

        <EditText
            android:id="@+id/et_invite_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search by name, email or phone"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- User list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_invite_users"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_invite_search" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_invite_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No users found"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_invite_search" />

</androidx.constraintlayout.widget.ConstraintLayout>
